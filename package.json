{
  "name": "@openprd/cli",
  "version": "0.1.15",
  "description": "AI-native PRD workspace and lifecycle CLI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "openprd": "bin/openprd.js"
  },
  "files": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "README_CN.md",
    "README_EN.md",
    "SECURITY.md",
    "bin",
    "scripts",
    "src",
    ".openprd",
    "!.openprd/artifacts",
    "!.openprd/artifacts/**",
    "!.openprd/benchmarks/evidence",
    "!.openprd/benchmarks/evidence/**",
    "!.openprd/benchmarks/inbox",
    "!.openprd/benchmarks/inbox/**",
    "!.openprd/discovery",
    "!.openprd/discovery/**",
    "!.openprd/engagements/active/architecture-diagram.html",
    "!.openprd/engagements/active/architecture-diagram.json",
    "!.openprd/engagements/active/architecture-diagram.mmd",
    "!.openprd/engagements/active/brainstorm.html",
    "!.openprd/engagements/active/brainstorm.json",
    "!.openprd/harness",
    "!.openprd/harness/**",
    "!.openprd/engagements/active/flows.md",
    "!.openprd/engagements/active/handoff.md",
    "!.openprd/engagements/active/product-flow-diagram.html",
    "!.openprd/engagements/active/product-flow-diagram.json",
    "!.openprd/engagements/active/product-flow-diagram.mmd",
    "!.openprd/engagements/active/review.html",
    "!.openprd/engagements/active/roles.md",
    "!.openprd/engagements/work-units",
    "!.openprd/engagements/work-units/**",
    "!.openprd/exports",
    "!.openprd/exports/**",
    "!.openprd/learning",
    "!.openprd/learning/**",
    "!.openprd/quality/evidence",
    "!.openprd/quality/evidence/**",
    "!.openprd/quality/reports",
    "!.openprd/quality/reports/**",
    "!.openprd/growth",
    "!.openprd/growth/**",
    "!.openprd/growth/preferences.local.json",
    "!.openprd/knowledge/incidents",
    "!.openprd/knowledge/incidents/**",
    "!.openprd/knowledge/patterns",
    "!.openprd/knowledge/patterns/**",
    "!.openprd/knowledge/skills",
    "!.openprd/knowledge/skills/**",
    "!.openprd/knowledge/adoption.jsonl",
    "!.openprd/knowledge/candidates",
    "!.openprd/knowledge/candidates/**",
    "!.openprd/knowledge/drafts",
    "!.openprd/knowledge/drafts/**",
    "!.openprd/knowledge/index.json",
    "!.openprd/knowledge/review-signals.jsonl",
    "!.openprd/reviews",
    "!.openprd/reviews/**",
    "!.openprd/sessions",
    "!.openprd/sessions/**",
    "!.openprd/state/changes.json",
    "!.openprd/state/current.json",
    "!.openprd/state/events.jsonl",
    "!.openprd/state/freeze.json",
    "!.openprd/state/release-ledger.json",
    "!.openprd/state/task-graph.json",
    "!.openprd/state/version-index.json",
    "!.openprd/state/versions",
    "!.openprd/state/versions/**",
    "!.openprd/engagements/active/decision-log.md",
    "!.openprd/engagements/active/open-questions.md",
    "!.openprd/engagements/active/progress.md",
    "!.openprd/engagements/active/verification.md",
    "skills"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node ./bin/openprd.js",
    "release:notes": "node scripts/openprd-github-release-notes.mjs",
    "test": "node --test",
    "test:smoke": "node --test --test-name-pattern \"quality requires current smoke evidence|run exposes hook-stable\"",
    "test:perf": "node scripts/quality-perf-check.mjs --mode normal",
    "test:perf:extreme": "node scripts/quality-perf-check.mjs --mode extreme --fixture test/fixtures/release-ledger-extreme.json"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "yaml": "^2.8.2"
  }
}
